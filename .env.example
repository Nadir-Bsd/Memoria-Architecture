DB_ROOT_PASSWORD=
DB_USER=
DB_PASSWORD=
DB_DATABASE=Memoria

# Configuration Frontend & Backend (Remplacer localhost par le nom de domaine ou l'IP en production)
CORS_ALLOW_ORIGIN=^http://localhost(:[0-9]+)?$
NEXT_PUBLIC_API_URL="http://localhost/api"

# URL de connexion (L'interpolation se fera automatiquement)
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@database:3306/${DB_DATABASE}?serverVersion=8.4&charset=utf8mb4"

# Environnement (dev en local, prod sur le VPS)
APP_ENV=dev

# Configuration IA
OLLAMA_BASE_URL=http://host.docker.internal:11434